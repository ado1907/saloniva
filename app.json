{
  "expo": {
    "name": "Saloniva",
    "slug": "saloniva",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "saloniva",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F0E6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saloniva.app"
    },
    "android": {
      "package": "com.saloniva.app",
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F0E6"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": []
  }
}
